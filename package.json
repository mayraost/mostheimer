{
  "name": "with-postgres",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "next build",
    "ci": "payload migrate && pnpm build",
    "dev": "next dev",
    "devsafe": "rm -rf .next && next dev",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "payload": "payload",
    "start": "next start",
    "test": "npm run test:int && npm run test:e2e",
    "test:e2e": "NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.78.0",
    "@payloadcms/db-sqlite": "3.78.0",
    "@payloadcms/next": "3.78.0",
    "@payloadcms/richtext-lexical": "3.78.0",
    "@payloadcms/ui": "3.78.0",
    "@tailwindcss/postcss": "^4.2.1",
    "dotenv": "^17.3.1",
    "graphql": "^16.13.0",
    "lucide-react": "^0.575.0",
    "next": "^16.2.0-canary.68",
    "payload": "3.78.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "^10.0.2",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "28.1.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=24",
    "npm": "^11"
  }
}
